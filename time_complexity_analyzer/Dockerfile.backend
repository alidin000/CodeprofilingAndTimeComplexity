FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    default-jdk \
    g++ \
    build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app/

RUN python manage.py collectstatic --noinput

EXPOSE 8000

# Single worker: async job state lives in LocMemCache (not shared across workers).
# Use Redis cache + multiple workers if you scale horizontally.
CMD ["bash", "-c", "python manage.py migrate && gunicorn time_complexity_analyzer.wsgi:application --bind 0.0.0.0:8000 --workers 1 --timeout 300"]
